{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/MA-HomeAssignment/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet, noimageindex" }
      ]
    },
    {
      "source": "/MA-HomeAssignment",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet, noimageindex" }
      ]
    },
    {
      "source": "/HA-DrawingAnalyzer/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet, noimageindex" }
      ]
    },
    {
      "source": "/HA-DrawingAnalyzer",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet, noimageindex" }
      ]
    },
    {
      "source": "/panel.glb",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Type", "value": "model/gltf-binary" }
      ]
    },
    {
      "source": "/architecture/:file*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/cv.pdf",
      "headers": [
        { "key": "Content-Disposition", "value": "attachment; filename=\"Eliahu_Cohen_CV.pdf\"" }
      ]
    }
  ]
}
